<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="MTrkUZK]W=A%IQ1jA)DD" x="33" y="-557"><statement name="HANDLER"><block type="typescript_statement" id="h{6}!(DFLOhwVk`O_ZJx"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace CBurgPinball {" line1="" line2="    export enum Gate {" line3="        //% block=&quot;gate 1&quot;" line4="        //% block.loc.nl=&quot;poortje 1&quot;" line5="        Gate1," line6="        //% block=&quot;gate 2&quot;" line7="        //% block.loc.nl=&quot;poortje 2&quot;" line8="        Gate2" line9="    }" line10="" line11="    export enum MediaId {" line12="        //% block=&quot;background&quot;" line13="        //% block.loc.nl=&quot;achtergrond&quot;" line14="        Background," line15="        //% block=&quot;video 1&quot;" line16="        //% block.loc.nl=&quot;video 1&quot;" line17="        Video1," line18="        //% block=&quot;video 2&quot;" line19="        //% block.loc.nl=&quot;video 2&quot;" line20="        Video2" line21="    }" line22="" line23="    //% block=&quot;show %mediaid&quot;" line24="    //% block.loc.nl=&quot;toon %mediaid&quot;" line25="    export function show( mediaid: MediaId) {" line26="        // do not change rgb-leds" line27="        pins.digitalWritePin(DigitalPin.P12, 0)" line28="        pins.digitalWritePin(DigitalPin.P13, 0)" line29="        // choose the medium" line30="        if (mediaid == MediaId.Background) {" line31="            pins.digitalWritePin(DigitalPin.P19, 1);" line32="            pins.digitalWritePin(DigitalPin.P20, 1);" line33="        }" line34="        if (mediaid == MediaId.Video1) {" line35="            pins.digitalWritePin(DigitalPin.P19, 1);" line36="            pins.digitalWritePin(DigitalPin.P20, 0);" line37="        }" line38="        if (mediaid == MediaId.Video2) {" line39="            pins.digitalWritePin(DigitalPin.P19, 0);" line40="            pins.digitalWritePin(DigitalPin.P20, 1);" line41="        }" line42="        // communicate to raspberry" line43="        pins.digitalWritePin(DigitalPin.P0, 1);" line44="        while (!pins.digitalReadPin(DigitalPin.P3));" line45="        pins.digitalWritePin(DigitalPin.P0, 1);" line46="    }" line47="" line48="    //% block=&quot;background&quot;" line49="    //% block.loc.nl=&quot;achtergrond&quot;" line50="    export function background(): MediaId {" line51="        return MediaId.Background;" line52="    }" line53="" line54="    //% block=&quot;video 1&quot;" line55="    //% block.loc.nl=&quot;video 1&quot;" line56="    export function video1(): MediaId {" line57="        return MediaId.Video1;" line58="    }" line59="" line60="    //% block=&quot;video 2&quot;" line61="    //% block=&quot;video 2&quot;" line62="    export function video2(): MediaId {" line63="        return MediaId.Video2;" line64="    }" line65="" line66="    //% block=&quot;gate 1&quot;" line67="    //% block.loc.nl=&quot;poortje 1&quot;" line68="    export function gate1(): Gate {" line69="        return Gate.Gate1;" line70="    }" line71="" line72="    //% block=&quot;gate 2&quot;" line73="    //% block.loc.nl=&quot;poortje 2&quot;" line74="    export function gate2(): Gate {" line75="        return Gate.Gate2;" line76="    }" line77="" line78="    //% block=&quot;not thru a gate&quot;" line79="    //% block.loc.nl=&quot;niet door een poortje&quot;" line80="    export function notThruGate(): boolean {" line81="        if ( pins.digitalReadPin( DigitalPin.P1) ||" line82="             pins.digitalReadPin( DigitalPin.P2) )" line83="            return false;" line84="        return true;" line85="    }" line86="" line87="    //% block=&quot;thru gate 1&quot;" line88="    //% block.loc.nl=&quot;door poortje 1&quot;" line89="    export function thruGate1(): boolean {" line90="        return (pins.digitalReadPin( DigitalPin.P1) == 1);" line91="    }" line92="" line93="    //% block=&quot;thru gate 2&quot;" line94="    //% block.loc.nl=&quot;door poortje 2&quot;" line95="    export function thruGate2(): boolean {" line96="        return (pins.digitalReadPin( DigitalPin.P2) == 1);" line97="    }" line98="" line99="    //% block=&quot;on thru %gate&quot;" line100="    //% block.loc.nl=&quot;wanneer door %gate&quot;" line101="    export function onEvent( gate: Gate, handler: () =&gt; void) {" line102="    }" line103="}" numlines="104"></mutation></block></statement></block></xml>