<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="eJt0Cjn3Nm_CcVQ0_t?2" x="80" y="53"><statement name="HANDLER"><block type="typescript_statement" id="wg5eg35Lc1-8rGhtn[D?"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace CBurgPinball {" line1="" line2="    export enum Gate {" line3="        //% block=&quot;gate 1&quot;" line4="        //% block.loc.nl=&quot;poortje 1&quot;" line5="        Gate1," line6="        //% block=&quot;gate 2&quot;" line7="        //% block.loc.nl=&quot;poortje 2&quot;" line8="        Gate2" line9="    }" line10="" line11="    export enum LedId {" line12="        //% block=&quot;led 1&quot;" line13="        //% block.loc.nl=&quot;led 1&quot;" line14="        Led1," line15="        //% block=&quot;led 2&quot;" line16="        //% block.loc.nl=&quot;led 2&quot;" line17="        Led2," line18="        //% block=&quot;led 3&quot;" line19="        //% block.loc.nl=&quot;led 3&quot;" line20="        Led3" line21="    }" line22="" line23="    export enum ColorId {" line24="        //% block=&quot;dark&quot;" line25="        //% block.loc.nl=&quot;donker&quot;" line26="        Off," line27="        //% block=&quot;red&quot;" line28="        //% block.loc.nl=&quot;rood&quot;" line29="        Red," line30="        //% block=&quot;yellow&quot;" line31="        //% block.loc.nl=&quot;geel&quot;" line32="        Yellow," line33="        //% block=&quot;green&quot;" line34="        //% block.loc.nl=&quot;groen&quot;" line35="        Green," line36="        //% block=&quot;light blue&quot;" line37="        //% block.loc.nl=&quot;lichtblauw&quot;" line38="        Cyan," line39="        //% block=&quot;blue&quot;" line40="        //% block.loc.nl=&quot;blauw&quot;" line41="        Blue," line42="        //% block=&quot;purple&quot;" line43="        //% block.loc.nl=&quot;paars&quot;" line44="        Magenta," line45="        //% block=&quot;white&quot;" line46="        //% block.loc.nl=&quot;wit&quot;" line47="        White" line48="    }" line49="    export enum MediaId {" line50="        //% block=&quot;background&quot;" line51="        //% block.loc.nl=&quot;achtergrond&quot;" line52="        Background," line53="        //% block=&quot;video 1&quot;" line54="        //% block.loc.nl=&quot;video 1&quot;" line55="        Video1," line56="        //% block=&quot;video 2&quot;" line57="        //% block.loc.nl=&quot;video 2&quot;" line58="        Video2" line59="    }" line60="" line61="    //% block=&quot;color %ledid %state&quot;" line62="    //% block.loc.nl=&quot;kleur %ledid %state&quot;" line63="    export function switchled(ledid: LedId, colorid: ColorId) {" line64="        // do not change media" line65="        pins.digitalWritePin(DigitalPin.P19, 0)" line66="        pins.digitalWritePin(DigitalPin.P20, 0)" line67="        // choose the led" line68="        if (ledid == LedId.Led1) {" line69="            pins.digitalWritePin(DigitalPin.P12, 0);" line70="            pins.digitalWritePin(DigitalPin.P13, 1);" line71="        }" line72="        else" line73="        if (ledid == LedId.Led2) {" line74="            pins.digitalWritePin(DigitalPin.P12, 1);" line75="            pins.digitalWritePin(DigitalPin.P13, 0);" line76="        }" line77="        else" line78="        if (ledid == LedId.Led3) {" line79="            pins.digitalWritePin(DigitalPin.P12, 1);" line80="            pins.digitalWritePin(DigitalPin.P13, 1);" line81="        }" line82="        // set the color" line83="        if (colorid == ColorId.Off) {" line84="            pins.digitalWritePin(DigitalPin.P14, 0);" line85="            pins.digitalWritePin(DigitalPin.P15, 0);" line86="            pins.digitalWritePin(DigitalPin.P16, 0);" line87="        }" line88="        if (colorid == ColorId.Red) {" line89="            pins.digitalWritePin(DigitalPin.P14, 1);" line90="            pins.digitalWritePin(DigitalPin.P15, 0);" line91="            pins.digitalWritePin(DigitalPin.P16, 0);" line92="        }" line93="        if (colorid == ColorId.Yellow) {" line94="            pins.digitalWritePin(DigitalPin.P14, 1);" line95="            pins.digitalWritePin(DigitalPin.P15, 1);" line96="            pins.digitalWritePin(DigitalPin.P16, 0);" line97="        }" line98="        if (colorid == ColorId.Green) {" line99="            pins.digitalWritePin(DigitalPin.P14, 0);" line100="            pins.digitalWritePin(DigitalPin.P15, 1);" line101="            pins.digitalWritePin(DigitalPin.P16, 0);" line102="        }" line103="        if (colorid == ColorId.Cyan) {" line104="            pins.digitalWritePin(DigitalPin.P14, 0);" line105="            pins.digitalWritePin(DigitalPin.P15, 1);" line106="            pins.digitalWritePin(DigitalPin.P16, 1);" line107="        }" line108="        if (colorid == ColorId.Blue) {" line109="            pins.digitalWritePin(DigitalPin.P14, 0);" line110="            pins.digitalWritePin(DigitalPin.P15, 0);" line111="            pins.digitalWritePin(DigitalPin.P16, 1);" line112="        }" line113="        if (colorid == ColorId.Magenta) {" line114="            pins.digitalWritePin(DigitalPin.P14, 1);" line115="            pins.digitalWritePin(DigitalPin.P15, 0);" line116="            pins.digitalWritePin(DigitalPin.P16, 1);" line117="        }" line118="        if (colorid == ColorId.White) {" line119="            pins.digitalWritePin(DigitalPin.P14, 1);" line120="            pins.digitalWritePin(DigitalPin.P15, 1);" line121="            pins.digitalWritePin(DigitalPin.P16, 1);" line122="        }" line123="        // communicate to raspberry" line124="        pins.digitalWritePin(DigitalPin.P0, 1);" line125="        while (!pins.digitalReadPin(DigitalPin.P3));" line126="        pins.digitalWritePin(DigitalPin.P0, 1);" line127="    }" line128="" line129="    //% block=&quot;show %mediaid&quot;" line130="    //% block.loc.nl=&quot;toon %mediaid&quot;" line131="    export function show( mediaid: MediaId) {" line132="        // do not change rgb-leds" line133="        pins.digitalWritePin(DigitalPin.P12, 0)" line134="        pins.digitalWritePin(DigitalPin.P13, 0)" line135="        // choose the medium" line136="        if (mediaid == MediaId.Background) {" line137="            pins.digitalWritePin(DigitalPin.P19, 1);" line138="            pins.digitalWritePin(DigitalPin.P20, 1);" line139="        }" line140="        else" line141="        if (mediaid == MediaId.Video1) {" line142="            pins.digitalWritePin(DigitalPin.P19, 0);" line143="            pins.digitalWritePin(DigitalPin.P20, 1);" line144="        }" line145="        else" line146="        if (mediaid == MediaId.Video2) {" line147="            pins.digitalWritePin(DigitalPin.P19, 1);" line148="            pins.digitalWritePin(DigitalPin.P20, 0);" line149="        }" line150="        // communicate to raspberry" line151="        pins.digitalWritePin(DigitalPin.P0, 1);" line152="        while (!pins.digitalReadPin(DigitalPin.P3));" line153="        pins.digitalWritePin(DigitalPin.P0, 1);" line154="    }" line155="" line156="    //% block=&quot;background&quot;" line157="    //% block.loc.nl=&quot;achtergrond&quot;" line158="    export function background(): MediaId {" line159="        return MediaId.Background;" line160="    }" line161="" line162="    //% block=&quot;video 1&quot;" line163="    //% block.loc.nl=&quot;video 1&quot;" line164="    export function video1(): MediaId {" line165="        return MediaId.Video1;" line166="    }" line167="" line168="    //% block=&quot;video 2&quot;" line169="    //% block=&quot;video 2&quot;" line170="    export function video2(): MediaId {" line171="        return MediaId.Video2;" line172="    }" line173="" line174="    //% block=&quot;gate 1&quot;" line175="    //% block.loc.nl=&quot;poortje 1&quot;" line176="    export function gate1(): Gate {" line177="        return Gate.Gate1;" line178="    }" line179="" line180="    //% block=&quot;gate 2&quot;" line181="    //% block.loc.nl=&quot;poortje 2&quot;" line182="    export function gate2(): Gate {" line183="        return Gate.Gate2;" line184="    }" line185="" line186="    //% block=&quot;not thru a gate&quot;" line187="    //% block.loc.nl=&quot;niet door een poortje&quot;" line188="    export function notThruGate(): boolean {" line189="        if ( pins.digitalReadPin( DigitalPin.P1) ||" line190="             pins.digitalReadPin( DigitalPin.P2) )" line191="            return false;" line192="        return true;" line193="    }" line194="" line195="    //% block=&quot;thru gate 1&quot;" line196="    //% block.loc.nl=&quot;door poortje 1&quot;" line197="    export function thruGate1(): boolean {" line198="        return (pins.digitalReadPin( DigitalPin.P1) == 1);" line199="    }" line200="" line201="    //% block=&quot;thru gate 2&quot;" line202="    //% block.loc.nl=&quot;door poortje 2&quot;" line203="    export function thruGate2(): boolean {" line204="        return (pins.digitalReadPin( DigitalPin.P2) == 1);" line205="    }" line206="" line207="    //% block=&quot;on thru %gate&quot;" line208="    //% block.loc.nl=&quot;wanneer door %gate&quot;" line209="    export function onEvent( gate: Gate, handler: () =&gt; void) {" line210="    }" line211="}" numlines="212"></mutation></block></statement></block></xml>